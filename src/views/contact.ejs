<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact | My Creative Portfolio</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
<%- include('partials/nav') %>
    <main>
        <h1>Get in Touch</h1>
        
        <div class="contact-container">
            <p class="contact-intro">
                Have a question or want to collaborate? I'd love to hear from you. 
                Drop me a message and I'll get back to you as soon as possible.
            </p>
            
            <section id="form_response"></section>
            
            <form id="contact_form" action="/contact" method="POST" class="contact-form">
                <div class="form-group">
                    <label for="name">Your Name</label>
                    <input type="text" id="name" name="name" placeholder="Enter your name" required>
                </div>
                
                <div class="form-group">
                    <label for="email">Your Email</label>
                    <input type="email" id="email" name="email" placeholder="Enter your email" required>
                </div>
                
                <div class="form-group">
                    <label for="message">Message</label>
                    <textarea id="message" name="message" placeholder="Share your thoughts or questions..." required></textarea>
                </div>
                
                <button type="submit">Send Message</button>
            </form>
        </div>
    </main>
    <script src="/js/contact.js" defer></script>
    <%- include('partials/footer') %>
</body>
</html>