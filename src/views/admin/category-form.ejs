<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= category ? 'Edit' : 'Create' %> Category - Admin</title>
    <link rel="stylesheet" href="/css/admin-style.css">
</head>

<body>
    <!-- Header Navigation -->
    <header>
        <nav>
            <h1>Admin Panel</h1>
            <a href="/admin">Dashboard</a>
            <a href="/admin/projects">Projects</a>
            <a href="/admin/categories" class="active">Categories</a>
            <a href="/admin/contacts">Messages</a>
            <a href="/">← Back to Portfolio</a>
        </nav>
    </header>

    <main>
        <div class="dashboard-container">
            <div class="mb-4">
                <h1><%= category ? 'Edit Category' : 'Create New Category' %></h1>
                <p class="text-muted"><%= category ? 'Update category information' : 'Add a new project category' %></p>
            </div>

            <form action="/admin/categories<%= category ? '/' + category._id : '' %>" method="POST" class="mt-3">
                <div class="form-group full">
                    <div class="form-item">
                        <label for="name">Category Name <span class="required">*</span></label>
                        <input type="text" id="name" name="name" value="<%= category ? category.name : '' %>" required>
                    </div>
                </div>

                <div class="form-group full">
                    <div class="form-item">
                        <label for="slug">Slug <span class="required">*</span></label>
                        <input type="text" id="slug" name="slug" value="<%= category ? category.slug : '' %>" required>
                        <p class="text-sm text-muted mt-1">URL-friendly name (e.g., web-development)</p>
                    </div>
                </div>

                <div class="form-group full">
                    <div class="form-item">
                        <label for="description">Description</label>
                        <textarea id="description" name="description" placeholder="Describe this category..."><%= category ? category.description : '' %></textarea>
                    </div>
                </div>

                <div class="flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">
                        <%= category ? 'Update Category' : 'Create Category' %>
                    </button>
                    <a href="/admin/categories" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </main>
</body>

</html>