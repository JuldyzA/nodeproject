<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= user ? 'Edit' : 'Create' %> User - Admin</title>
    <link rel="stylesheet" href="/css/admin-style.css">
</head>

<body>
    <%- include("partials/nav", { activePage: "users" }) %>

    <main>
        <div class="dashboard-container">
            <div class="mb-4">
                <h1><%= user ? 'Edit User' : 'Create New User' %></h1>
                <p class="text-muted"><%= user ? 'Update account fields and role' : 'Add a new user account' %></p>
            </div>

            <% if (error) { %>
            <div class="alert alert-danger"><%= error %></div>
            <% } %>

            <form action="/admin/users<%= user ? '/' + user._id : '' %>" method="POST" class="mt-3">
                <div class="form-group">
                    <div class="form-item">
                        <label for="nickname">Nickname <span class="required">*</span></label>
                        <input type="text" id="nickname" name="nickname" value="<%= user ? user.nickname : '' %>" required>
                    </div>

                    <div class="form-item">
                        <label for="email">Email <span class="required">*</span></label>
                        <input type="email" id="email" name="email" value="<%= user ? user.email : '' %>" required>
                    </div>
                </div>

                <div class="form-group">
                    <div class="form-item">
                        <label for="role">Role <span class="required">*</span></label>
                        <select id="role" name="role" required>
                            <% roles.forEach(role => { %>
                            <option value="<%= role %>" <%= user && user.role === role ? 'selected' : '' %>><%= role %></option>
                            <% }) %>
                        </select>
                    </div>

                    <div class="form-item">
                        <label for="password"><%= user ? 'New Password (optional)' : 'Password' %> <%= user ? '' : '*' %></label>
                        <input type="password" id="password" name="password" <%= user ? '' : 'required' %> minlength="6">
                    </div>
                </div>

                <div class="form-group full">
                    <div class="form-item">
                        <label for="confirmPassword"><%= user ? 'Confirm New Password' : 'Confirm Password' %> <%= user ? '' : '*' %></label>
                        <input type="password" id="confirmPassword" name="confirmPassword" <%= user ? '' : 'required' %> minlength="6">
                    </div>
                </div>

                <div class="flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary"><%= user ? 'Update User' : 'Create User' %></button>
                    <a href="/admin/users" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </main>
</body>

</html>
