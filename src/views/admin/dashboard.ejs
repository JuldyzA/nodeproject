<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard</title>
    <link rel="stylesheet" href="/css/admin-style.css">
</head>

<body>
    <!-- Header Navigation -->
    <header>
        <nav>
            <h1>Admin Panel</h1>
            <a href="/admin" class="active">Dashboard</a>
            <a href="/admin/projects">Projects</a>
            <a href="/admin/categories">Categories</a>
            <a href="/admin/contacts">Messages</a>
            <a href="/">← Back to Portfolio</a>
        </nav>
    </header>

    <main>
        <div class="dashboard-container">
            <h1>Welcome to Admin Dashboard</h1>
            <p class="text-muted">Manage your portfolio content from here</p>

            <div class="dashboard-grid">
                <div class="stat-card">
                    <h3>Projects</h3>
                    <p class="stat-value"><%= projectCount || 0 %></p>
                    <a href="/admin/projects" class="btn btn-sm btn-primary">Manage Projects</a>
                </div>
                <div class="stat-card">
                    <h3>Categories</h3>
                    <p class="stat-value"><%= categoryCount || 0 %></p>
                    <a href="/admin/categories" class="btn btn-sm btn-primary">Manage Categories</a>
                </div>
                <div class="stat-card">
                    <h3>Messages</h3>
                    <p class="stat-value"><%= unreadCount || 0 %></p>
                    <a href="/admin/contacts" class="btn btn-sm btn-primary">View Messages</a>
                </div>
            </div>

            <div class="card mt-4">
                <div class="card-header">
                    <h3>Quick Navigation</h3>
                </div>
                <div class="card-body">
                    <div class="btn-group">
                        <a href="/admin/projects/new" class="btn btn-primary">+ New Project</a>
                        <a href="/admin/categories/new" class="btn btn-secondary">+ New Category</a>
                    </div>
                </div>
            </div>
        </div>
    </main>
</body>

</html>