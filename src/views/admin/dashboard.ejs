<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard</title>
    <link rel="stylesheet" href="/css/admin-style.css">
</head>

<body>
    <%- include("partials/nav", { activePage: "dashboard" }) %>

    <main>
        <div class="dashboard-container">
            <% if (error) { %>
            <div class="alert alert-danger"><%= error %></div>
        <% } %>
            <h1>Welcome to Your Workspace</h1>
            <p class="text-muted">Review and manage the areas available to your <%= currentUser && currentUser.role ? currentUser.role.toLowerCase() : "team" %> account.</p>

            <div class="dashboard-grid">
                <% if (currentUser && currentUser.role === "ADMIN") { %>
                <div class="stat-card">
                    <h3>Projects</h3>
                    <p class="stat-value"><%= projectCount || 0 %></p>
                    <a href="/admin/projects" class="btn btn-sm btn-primary">Manage Projects</a>
                </div>
                <div class="stat-card">
                    <h3>Categories</h3>
                    <p class="stat-value"><%= categoryCount || 0 %></p>
                    <a href="/admin/categories" class="btn btn-sm btn-primary">Manage Categories</a>
                </div>
                <div class="stat-card">
                    <h3>Users</h3>
                    <p class="stat-value"><%= usersCount || 0 %></p>
                    <a href="/admin/users" class="btn btn-sm btn-primary">Manage Users</a>
                </div>
                <% } %>
                <div class="stat-card">
                    <h3>Messages</h3>
                    <p class="stat-value"><%= unreadCount || 0 %></p>
                    <a href="/admin/contacts" class="btn btn-sm btn-primary">View Messages</a>
                </div>
            </div>

            <% if (currentUser && currentUser.role === "ADMIN") { %>
            <div class="card mt-4">
                <div class="card-header">
                        <h3>Quick Actions</h3>
                </div>
                <div class="card-body">
                    <div class="btn-group">
                        <a href="/admin/projects/new" class="btn btn-primary">+ New Project</a>
                        <a href="/admin/categories/new" class="btn btn-secondary">+ New Category</a>
                        <a href="/admin/users/new" class="btn btn-info">+ New User</a>
                    </div>
                </div>
            </div>

            <div class="card mt-4">
                <div class="card-header">
                    <h3>Recent Security Events</h3>
                </div>
                <div class="card-body">
                    <% if (securityEvents && securityEvents.length > 0) { %>
                    <div style="overflow-x: auto;">
                        <table>
                            <thead>
                                <tr>
                                    <th>Time</th>
                                    <th>Role</th>
                                    <th>Method</th>
                                    <th>Path</th>
                                    <th>Required Role</th>
                                    <th>IP</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% securityEvents.forEach(event => { %>
                                <tr>
                                    <td>
                                        <%= new Date(event.timestamp).toLocaleString("en-CA", {
                                            timeZone: appTimeZone,
                                            dateStyle: "medium",
                                            timeStyle: "short"
                                        }) %>
                                    </td>
                                    <td><span class="badge badge-secondary"><%= event.role %></span></td>
                                    <td><%= event.method %></td>
                                    <td><code><%= event.path %></code></td>
                                    <td><%= event.requiredRole %></td>
                                    <td><%= event.ip || "-" %></td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                    <% } else { %>
                    <p class="text-muted">No unauthorized access attempts logged yet.</p>
                    <% } %>
                </div>
            </div>
            <% } %>
        </div>
    </main>
</body>

</html>
