<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= project.title %> | My Creative Portfolio</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

    <%- include('partials/nav') %>

    <main class="page-container-wide project-layout">

         <%- include('other-projects') %>

        <div class="project-content">

        <!-- Project Title -->
        <h1><%= project.title %></h1>

        <% if (project.tagline) { %>
            <p class="projects-intro"><%= project.tagline %></p>
        <% } %>

        <% 
          const featuredImage = project.projectImages?.find(img => img.isFeatured);
          const galleryImages = project.projectImages?.filter(img => !img.isFeatured);
        %>

        <!-- Featured Image -->
        <% if (featuredImage) { %>
            <img 
                src="<%= featuredImage.urlPath || ('/uploads/' + project.slug + '/' + featuredImage.filename) %>" 
                alt="<%= featuredImage.altText || project.title %>" 
                class="project-image"
            >
            <% if (featuredImage.caption) { %>
                <p class="project-figcaption"><%= featuredImage.caption %></p>
            <% } %>
        <% } %>

        <!-- Description -->
        <section class="card-section">
            <h2>About This Project</h2>
            <p><%= project.description %></p>
        </section>

        <!-- Category -->
        <% if (project.categoryId) { %>
            <section class="card-section">
                <h2>Category</h2>
                <p>
                    <%= project.categoryId.name ? project.categoryId.name : project.categoryId %>
                </p>
            </section>
        <% } %>

        <!-- Stack -->
        <% if (project.stack && project.stack.length > 0) { %>
            <section class="card-section">
                <h2>Tech Stack</h2>
                <div class="tags">
                    <% project.stack.forEach(item => { %>
                        <span class="tag"><%= item %></span>
                    <% }) %>
                </div>
            </section>
        <% } %>

        <!-- Tags -->
        <% if (project.tags && project.tags.length > 0) { %>
            <section class="card-section">
                <h2>Tags</h2>
                <div class="tags">
                    <% project.tags.forEach(tag => { %>
                        <a href="/projects?tag=<%= encodeURIComponent(tag.name) %>" class="tag"><%= tag.name%></a>
                       
                    <% }) %>
                </div>
            </section>
        <% } %>

        <!-- Gallery -->
        <% if (galleryImages && galleryImages.length > 0) { %>
            <section class="card-section">
                <h2>Gallery</h2>
                <div class="project-gallery">
                    <% galleryImages.forEach(image => { %>
                        <figure class="project-figure">
                            <img 
                                src="<%= image.urlPath || ('/uploads/' + project.slug + '/' + image.filename) %>" 
                                alt="<%= image.altText || project.title %>" 
                                class="project-image"
                            >
                            <% if (image.caption) { %>
                                <figcaption class="project-figcaption">
                                    <%= image.caption %>
                                </figcaption>
                            <% } %>
                        </figure>
                    <% }) %>
                </div>
            </section>
        <% } %>

        <!-- Back Button -->
        <div class="cta-buttons-container">
            <a href="/projects" class="cta-button cta-button-secondary">
                ← Back to Projects
            </a>
        </div>

        </div>
    </main>

    <%- include('partials/footer') %>

</body>
</html>