<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Projects | My Creative Portfolio</title>
    <link rel="stylesheet" href="/css/styles.css">

</head>
<body>
    <%- include('partials/nav') %>

    <main>
        <h1>My Projects</h1>
        <p class="projects-intro">
            Here's a collection of my favorite projects where I've blended creativity with technology.
            Click on any project to learn more about the process and what makes it special.
        </p>
        <% if (selectedTag) { %>
        <p class="projects-intro">
            Showing projects tagged: <strong><%= selectedTag %></strong>
            | <a href="/projects" class="project-link">Clear filter</a>
        </p>
        <% } %>
        <div id="projectsGrid">
        <% if (projects && projects.length > 0) { %>
            <% projects.forEach(project => { %>
                <%- include('partials/projects-list-item', { project: project }) %>
            <% }) %>
        <% } else { %>
            <p class="loading-text">No projects found.</p>
        <% } %>
        </div>
    </main>

    <%- include('partials/footer') %>
    <script src="/js/project.js" defer></script>
</body>
</html>