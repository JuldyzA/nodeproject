<div id="projectsGrid">

<% if (projects && projects.length > 0) { %>

  <% projects.forEach(project => { %>

    <article class="project-card" data-href="/projects/<%= project.slug %>">

      <h3><%= project.title %></h3>

      <% if (project.description) { %>
        <p><%= project.description %></p>
      <% } %>

      <% if (project.stack) { %>
        <p>
          <strong>Stack:</strong>
          <%= project.stack.join(", ") %>
        </p>
      <% } %>

      <a href="/projects/<%= project.slug %>" class="project-link">
        View project
      </a>

    </article>

  <% }) %>

<% } else { %>

  <p class="loading-text">No projects found.</p>

<% } %>

</div>